prefix=/Users/bharathy/Open-Sora-All/xz-install
exec_prefix=/Users/bharathy/Open-Sora-All/xz-install
libdir=/Users/bharathy/Open-Sora-All/xz-install/lib
includedir=/Users/bharathy/Open-Sora-All/xz-install/include

Name: liblzma
Description: General purpose data compression library
URL: https://tukaani.org/xz/
Version: 5.4.5
Cflags: -I${includedir}
Cflags.private: -DLZMA_API_STATIC
Libs: -L${libdir} -llzma
Libs.private: -pthread -lpthread
